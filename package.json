{
  "name": "young-post",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "format": "biome format --write .",
    "format:check": "biome ci --linter-enabled=false --assist-enabled=false .",
    "lint": "biome ci --formatter-enabled=false --assist-enabled=false .",
    "plan:check": "node .agents/scripts/check-plan-lifecycle.mjs",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run plan:check",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@samyng/h-alter": "^0.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "lefthook": "^1.13.6",
    "nano-staged": "^1.0.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
