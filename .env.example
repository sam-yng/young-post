# Neon Postgres connection string (pooled), from the Neon dashboard
DATABASE_URL=

# Same string with the `-pooler` host suffix removed. CLI-only: Prisma Migrate
# needs a direct connection (advisory locks fail through PgBouncer)
DIRECT_DATABASE_URL=

# Auth.js (Google SSO only)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Shared secret for cron-triggered routes (/api/ingest), sent as a request header
CRON_SECRET=
